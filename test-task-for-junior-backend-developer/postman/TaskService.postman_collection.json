{
  "info": {
    "name": "Task Service API",
    "description": "Примеры запросов для тестового задания (поменяй переменную baseUrl).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "taskId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "List tasks",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/v1/tasks"
      }
    },
    {
      "name": "Create task (with recurrence template)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Ежедневный обзвон\",\n  \"description\": \"Позвонить пациентам\",\n  \"status\": \"new\",\n  \"recurrence\": {\n    \"type\": \"daily\",\n    \"interval_days\": 2\n  }\n}"
        },
        "url": "{{baseUrl}}/api/v1/tasks"
      }
    },
    {
      "name": "Get task by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}"
      }
    },
    {
      "name": "Generate instances from template",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"from_date\": \"2026-04-01\",\n  \"to_date\": \"2026-04-10\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}"
      }
    },
    {
      "name": "Update task",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Обновлённый заголовок\",\n  \"description\": \"\",\n  \"status\": \"in_progress\",\n  \"recurrence\": {\n    \"type\": \"monthly_day\",\n    \"monthly_day\": 15\n  }\n}"
        },
        "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}"
      }
    },
    {
      "name": "Delete task",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}"
      }
    }
  ]
}
